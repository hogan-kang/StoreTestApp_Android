require 'fileutils'

default_platform(:android)

platform :android do
  desc "Upload to Google Play Store"
  lane :deploy do |options|
    timestamp = Time.now.strftime("%Y-%m-%d %H:%M:%S")
    
    # 1. Create Release Notes directly in the standard fastlane/metadata folder
    # Use absolute path to ensure Fastlane can locate it in any environment
    metadata_base = File.join(Dir.pwd, "fastlane", "metadata")

    # Cover all possible Chinese variants and English
    locales = ["en-US", "zh-CN", "zh-HK"]

    locales.each do |locale|
      # Fastlane expects locale folders directly under the metadata path.
      changelog_dir = File.join(metadata_base, locale, "changelogs")
      FileUtils.mkdir_p(changelog_dir)
      File.write(File.join(changelog_dir, "default.txt"), "Automated release at #{timestamp}")
    end

    # 2. Upload to Google Play
    upload_to_play_store(
      package_name: "com.hogan.kang.storetest",
      json_key_data: ENV['SERVICE_ACCOUNT_JSON'],
      track: "internal",
      release_status: "completed",
      aab: "app/build/outputs/bundle/release/app-release-signed.aab",

      # Use the standard metadata folder
      metadata_path: metadata_base,

      # Clear the App bundles list in the release draft
      version_codes_to_retain: [],

      # FIXED: Set skip_upload_metadata to true to avoid "missing title" errors for new locales.
      # Setting this to true skips syncing Title/Description but ALLOWS changelogs if skip_upload_changelogs is false.
      skip_upload_metadata: true,
      skip_upload_changelogs: false,

      # Skip large asset uploads for speed
      skip_upload_apk: true,
      skip_upload_images: true,
      skip_upload_screenshots: true
    )
  end
end
