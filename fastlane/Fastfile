require 'fileutils'

default_platform(:android)

platform :android do
  desc "Upload to Google Play Store"
  lane :deploy do |options|
    timestamp = Time.now.strftime("%Y-%m-%d %H:%M:%S")
    
    # 1. Prepare Release Notes (Metadata)
    # Generating for multiple locales to ensure coverage in Google Play
    locales = ["en-US", "zh-CN"]
    locales.each do |locale|
      path = "fastlane/metadata/android/#{locale}/changelogs"
      FileUtils.mkdir_p(path)
      File.write("#{path}/default.txt", "Automated release at #{timestamp}")
    end

    # 2. Upload to Google Play
    upload_to_play_store(
      package_name: "com.hogan.kang.storetest",
      json_key_data: ENV['SERVICE_ACCOUNT_JSON'], 
      track: "internal",
      release_status: "draft",
      aab: "app/build/outputs/bundle/release/app-release-signed.aab",
      
      # Explicitly set metadata path
      metadata_path: "fastlane/metadata",
      
      # Ensure only the current AAB is included in the release draft
      version_codes_to_retain: [], 
      
      # Enable metadata/changelog upload
      skip_upload_metadata: false,
      skip_upload_changelogs: false,
      
      # Skip images and APKs for speed
      skip_upload_apk: true,
      skip_upload_images: true,
      skip_upload_screenshots: true
    )
    
    # 3. Optional: Cleanup generated metadata after upload
    FileUtils.rm_rf("fastlane/metadata")
  end
end
